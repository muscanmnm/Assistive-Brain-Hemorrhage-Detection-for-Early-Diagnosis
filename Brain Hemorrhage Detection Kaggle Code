ls clipped below -100 HU : 178,008 (67.9%)\n  Pixels clipped above  200 HU : 25,225 (9.6%)\n  Pixels kept in range          : 58,911 (22.5%)\n\nPOSITIVE:\n  Pixels clipped below -100 HU : 166,045 (63.3%)\n  Pixels clipped above  200 HU : 14,551 (5.6%)\n  Pixels kept in range          : 81,548 (31.1%)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x500 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"✅ Figure saved to outputs/figures/hu_clipping_impact.png\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"# ── Windowing Functions ────────────────────────────────────\ndef apply_window(hu_image, level, width):\n    \"\"\"Apply CT window and normalize to [0, 255] uint8.\"\"\"\n    lower    = level - (width / 2.0)\n    upper    = level + (width / 2.0)\n    windowed = np.clip(hu_image, lower, upper)\n    windowed = (windowed - lower) / (upper - lower) * 255.0\n    return windowed.astype(np.uint8)\n\ndef create_rgb_window(hu_image):\n    \"\"\"\n    Stack 3 windows as RGB channels.\n    Red   : Brain window    (L:40,  W:80)\n    Green : Subdural window (L:80,  W:200)\n    Blue  : Bone window     (L:600, W:2800)\n    Returns (H, W, 3) uint8 image.\n    \"\"\"\n    brain    = apply_window(hu_image, **WINDOWS['brain'])\n    subdural = apply_window(hu_image, **WINDOWS['subdural'])\n    bone     = apply_window(hu_image, **WINDOWS['bone'])\n    return np.stack([brain, subdural, bone], axis=-1)\n\nprint(\"✅ Windowing functions defined.\")\n\n# ── Apply to both cases using CLIPPED HU ──────────────────\nneg_brain    = apply_window(neg_clipped, **WINDOWS['brain'])\nneg_subdural = apply_window(neg_clipped, **WINDOWS['subdural'])\nneg_bone     = apply_window(neg_clipped, **WINDOWS['bone'])\nneg_rgb      = create_rgb_window(neg_clipped)\n\npos_brain    = apply_window(pos_clipped, **WINDOWS['brain'])\npos_subdural = apply_window(pos_clipped, **WINDOWS['subdural'])\npos_bone     = apply_window(pos_clipped, **WINDOWS['bone'])\npos_rgb      = create_rgb_window(pos_clipped)\n\n# ── Verification ───────────────────────────────────────────\nprint(f\"\\n📋 Negative Slice Window Outputs:\")\nprint(f\"  Brain    : shape={neg_brain.shape}, range=[{neg_brain.min()}, {neg_brain.max()}]\")\nprint(f\"  Subdural : shape={neg_subdural.shape}, range=[{neg_subdural.min()}, {neg_subdural.max()}]\")\nprint(f\"  Bone     : shape={neg_bone.shape}, range=[{neg_bone.min()}, {neg_bone.max()}]\")\nprint(f\"  RGB      : shape={neg_rgb.shape}, dtype={neg_rgb.dtype}\")\n\nprint(f\"\\n📋 Positive Slice Window Outputs:\")\nprint(f\"  Brain    : shape={pos_brain.shape}, range=[{pos_brain.min()}, {pos_brain.max()}]\")\nprint(f\"  Subdural : shape={pos_subdural.shape}, range=[{pos_subdural.min()}, {pos_subdural.max()}]\")\nprint(f\"  Bone     : shape={pos_bone.shape}, range=[{pos_bone.min()}, {pos_bone.max()}]\")\nprint(f\"  RGB      : shape={pos_rgb.shape}, dtype={pos_rgb.dtype}\")\n\n# ── Visualization ──────────────────────────────────────────\nfig, axes = plt.subplots(2, 5, figsize=(20, 9))\nfig.suptitle('Multi-Window RGB Strategy — Negative vs Positive',\n             fontsize=14, fontweight='bold', y=1.01)\n\ncases = [\n    (neg_brain, neg_subdural, neg_bone, neg_rgb, neg_id,      'NEGATIVE (Healthy)'),\n    (pos_brain, pos_subdural, pos_bone, pos_rgb, positive_id, 'POSITIVE (SAH)'),\n]\n\ncol_titles = ['Brain Window\\n(L:40, W:80)\\nRed Channel',\n              'Subdural Window\\n(L:80, W:200)\\nGreen Channel',\n              'Bone Window\\n(L:600, W:2800)\\nBlue Channel',\n              'RGB Composite\\n(Float32 [0,1])\\nCNN Input',\n              'Individual\\nChannels\\nColored']\n\nfor col, title in enumerate(col_titles):\n    axes[0, col].set_title(title, fontsize=9, fontweight='bold')\n\nfor row, (brain, subdural, bone, rgb, s_id, label) in enumerate(cases):\n\n    rgb_norm = rgb.astype(np.float32) / 255.0\n    h, w     = brain.shape\n\n    # Col 1: Brain window\n    axes[row, 0].imshow(brain, cmap='gray')\n    axes[row, 0].set_ylabel(label, fontsize=10, fontweight='bold',\n                            rotation=90, labelpad=10)\n    axes[row, 0].axis('off')\n\n    # Col 2: Subdural window\n    axes[row, 1].imshow(subdural, cmap='gray')\n    axes[row, 1].axis('off')\n\n    # Col 3: Bone window\n    axes[row, 2].imshow(bone, cmap='gray')\n    axes[row, 2].axis('off')\n\n    # Col 4: RGB composite\n    axes[row, 3].imshow(rgb_norm)\n    axes[row, 3].axis('off')\n\n    # Col 5: Colored individual channels\n    colored = np.zeros((h, w, 3), dtype=np.float32)\n    colored[:, :, 0] = brain.astype(np.float32)    / 255.0  # Red\n    colored[:, :, 1] = subdural.astype(np.float32) / 255.0  # Green\n    colored[:, :, 2] = bone.astype(np.float32)     / 255.0  # Blue\n    axes[row, 4].imshow(colored)\n    axes[row, 4].axis('off')\n\nplt.tight_layout()\nplt.savefig(f\"{FIGURES_DIR}/multiwindow_rgb.png\", dpi=150, bbox_inches='tight')\nplt.show()\n\nprint(f\"✅ Figure saved to {FIGURES_DIR}/multiwindow_rgb.png\")\nprint(f\"\\n📋 Output Summary:\")\nprint(f\"  Negative RGB : shape={neg_rgb.shape}, dtype={neg_rgb.dtype}\")\nprint(f\"  Positive RGB : shape={pos_rgb.shape}, dtype={pos_rgb.dtype}\")\nprint(f\"\\n✅ Windowing step complete. Ready for resizing.\")\n\n\n# ── Resizing Function ──────────────────────────────────────\ndef resize_rgb(rgb_image, target_size=IMAGE_SIZE):\n    \"\"\"\n    Resize each channel of RGB image to target_size × target_size.\n    Input  : (H, W, 3) uint8\n    Output : (3, target_size, target_size) float32 normalized to [0, 1]\n    \"\"\"\n    resized = np.stack([\n        cv2.resize(rgb_image[:, :, c], (target_size, target_size),\n                   interpolation=cv2.INTER_LINEAR)\n        for c in range(3)\n    ], axis=0)\n    return resized.astype(np.float32) / 255.0\n\nprint(\"✅ resize_rgb function defined.\")\n\n# ── Apply to both cases ────────────────────────────────────\nneg_resized = resize_rgb(neg_rgb)\npos_resized = resize_rgb(pos_rgb)\n\n# ── Verification ───────────────────────────────────────────\nprint(f\"\\n📋 Resize Verification:\")\nprint(f\"  Negative : {neg_rgb.shape} → {neg_resized.shape}\")\nprint(f\"  Positive : {pos_rgb.shape} → {pos_resized.shape}\")\nprint(f\"  dtype    : {neg_resized.dtype}\")\nprint(f\"  range    : [{neg_resized.min():.3f}, {neg_resized.max():.3f}]\")\n\n# ── Visualization ──────────────────────────────────────────\nfig, axes = plt.subplots(2, 2, figsize=(10, 9))\nfig.suptitle(f'Resizing — 512×512 → {IMAGE_SIZE}×{IMAGE_SIZE}',\n             fontsize=13, fontweight='bold')\n\ncases = [\n    (neg_rgb, neg_resized, neg_id,      'NEGATIVE (Healthy)'),\n    (pos_rgb, pos_resized, positive_id, 'POSITIVE (SAH)'),\n]\n\nfor row, (rgb_orig, rgb_resized, s_id, label) in enumerate(cases):\n    orig_norm = rgb_orig.astype(np.float32) / 255.0\n\n    # Col 1: Before resize\n    axes[row, 0].imshow(orig_norm)\n    axes[row, 0].set_title(f'{label}\\nBefore: {rgb_orig.shape[0]}×{rgb_orig.shape[1]}',\n                           fontsize=10, fontweight='bold')\n    axes[row, 0].axis('off')\n\n    # Col 2: After resize — transpose (3,H,W) → (H,W,3) for display\n    axes[row, 1].imshow(rgb_resized.transpose(1, 2, 0))\n    axes[row, 1].set_title(f'{label}\\nAfter: {IMAGE_SIZE}×{IMAGE_SIZE}',\n                           fontsize=10, fontweight='bold')\n    axes[row, 1].axis('off')\n\nplt.tight_layout()\nplt.savefig(f\"{FIGURES_DIR}/resizing.png\", dpi=150, bbox_inches='tight')\nplt.show()\n\nprint(f\"✅ Figure saved to {FIGURES_DIR}/resizing.png\")\nprint(f\"\\n✅ Resizing step complete. Ready for preprocess_dicom().\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T18:31:21.160604Z","iopub.execute_input":"2026-04-27T18:31:21.160920Z","iopub.status.idle":"2026-04-27T18:31:24.516465Z","shell.execute_reply.started":"2026-04-27T18:31:21.160897Z","shell.execute_reply":"2026-04-27T18:31:24.515631Z"}},"outputs":[{"name":"stdout","text":"✅ Windowing functions defined.\n\n📋 Negative Slice Window Outputs:\n  Brain    : shape=(512, 512), range=[0, 255]\n  Subdural : shape=(512, 512), range=[0, 255]\n  Bone     : shape=(512, 512), range=[63, 91]\n  RGB      : shape=(512, 512, 3), dtype=uint8\n\n📋 Positive Slice Window Outputs:\n  Brain    : shape=(512, 512), range=[0, 255]\n  Subdural : shape=(512, 512), range=[0, 255]\n  Bone     : shape=(512, 512), range=[63, 91]\n  RGB      : shape=(512, 512, 3), dtype=uint8\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 2000x900 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"✅ Figure saved to outputs/figures/multiwindow_rgb.png\n\n📋 Output Summary:\n  Negative RGB : shape=(512, 512, 3), dtype=uint8\n  Positive RGB : shape=(512, 512, 3), dtype=uint8\n\n✅ Windowing step complete. Ready for resizing.\n✅ resize_rgb function defined.\n\n📋 Resize Verification:\n  Negative : (512, 512, 3) → (3, 300, 300)\n  Positive : (512, 512, 3) → (3, 300, 300)\n  dtype    : float32\n  range    : [0.000, 1.000]\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x900 with 4 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"✅ Figure saved to outputs/figures/resizing.png\n\n✅ Resizing step complete. Ready for preprocess_dicom().\n","output_type":"stream"}],"execution_count":7},{"cell_type":"code","source":"def preprocess_dicom(dicom_path, target_size=IMAGE_SIZE):\n    \"\"\"\n    Full preprocessing pipeline for one DICOM slice.\n\n    Steps:\n      1. Read DICOM & convert raw pixels to Hounsfield Units (HU)\n      2. Clip HU to brain range [HU_MIN_BRAIN, HU_MAX_BRAIN]\n      3. Apply multi-window RGB strategy (Brain, Subdural, Bone)\n      4. Resize to target_size × target_size\n      5. Normalize to [0, 1] float32\n\n    Args:\n      dicom_path  : full path to .dcm file\n      target_size : output image size (default: IMAGE_SIZE from config)\n\n    Returns:\n      image    : np.ndarray (3, target_size, target_size) float32\n      metadata : dict with slice_id and patient_id\n    \"\"\"\n\n    # ── Step 1: Read DICOM & convert to HU ────────────────\n    dcm       = pydicom.dcmread(dicom_path)\n    raw       = dcm.pixel_array.astype(np.float32)\n    slope     = float(dcm.RescaleSlope)     if hasattr(dcm, 'RescaleSlope')     else 1.0\n    intercept = float(dcm.RescaleIntercept) if hasattr(dcm, 'RescaleIntercept') else 0.0\n    hu        = raw * slope + intercept\n\n    # ── Step 2: Clip HU to brain range ────────────────────\n    hu_clipped = clip_hu(hu)\n\n    # ── Step 3: Multi-window RGB ───────────────────────────\n    rgb = create_rgb_window(hu_clipped)\n\n    # ── Step 4 & 5: Resize + Normalize ────────────────────\n    image = resize_rgb(rgb, target_size)\n\n    # ── Metadata ───────────────────────────────────────────\n    metadata = {\n        'slice_id'   : os.path.basename(dicom_path).replace('.dcm', ''),\n        'patient_id' : str(dcm.PatientID) if hasattr(dcm, 'PatientID') else 'Unknown',\n    }\n\n    return image, metadata\n\nprint(\"✅ preprocess_dicom() function defined.\")\n\n# ── Test on both cases ─────────────────────────────────────\nneg_path = os.path.join(TRAIN_DICOM_DIR, f\"{neg_id}.dcm\")\npos_path = os.path.join(TRAIN_DICOM_DIR, f\"{positive_id}.dcm\")\n\nneg_out, neg_meta = preprocess_dicom(neg_path)\npos_out, pos_meta = preprocess_dicom(pos_path)\n\n# ── Verification ───────────────────────────────────────────\nprint(f\"\\n📋 Pipeline Output Verification:\")\nprint(f\"  Negative : shape={neg_out.shape}, dtype={neg_out.dtype}, \"\n      f\"range=[{neg_out.min():.3f}, {neg_out.max():.3f}]\")\nprint(f\"  Positive : shape={pos_out.shape}, dtype={pos_out.dtype}, \"\n      f\"range=[{pos_out.min():.3f}, {pos_out.max():.3f}]\")\nprint(f\"\\n📋 Metadata:\")\nprint(f\"  Negative : {neg_meta}\")\nprint(f\"  Positive : {pos_meta}\")\n\n# ── Speed Benchmark ────────────────────────────────────────\nimport time\ntimes