        nn.Linear(512, 6)               # Final output: 512 → 6 logits\n        )\n\n    def freeze_backbone(self):\n        \"\"\"\n        Phase 1: Freeze all backbone feature layers.\n        Only the classifier head remains trainable.\n        Forces model to learn CT → label mapping without\n        destroying pretrained ImageNet features.\n        \"\"\"\n        for param in self.backbone.features.parameters():\n            param.requires_grad = False\n        for param in self.backbone.classifier.parameters():\n            param.requires_grad = True\n\n    def unfreeze_top_blocks(self):\n        \"\"\"\n        Phase 2: Unfreeze top 2 MBConv blocks of EfficientNet-B3\n        (blocks 6 and 7) plus the classifier head.\n        These are the highest-level feature extractors — closest to\n        the classifier — so they benefit most from CT-specific fine-tuning.\n        Lower blocks stay frozen — their low-level edge/texture features\n        are shared between ImageNet and CT and do not need updating.\n        \"\"\"\n        # First freeze everything\n        for param in self.backbone.features.parameters():\n            param.requires_grad = False\n\n        # Then unfreeze only blocks 6 and 7 (0-indexed)\n        for param in self.backbone.features[6].parameters():\n            param.requires_grad = True\n        for param in self.backbone.features[7].parameters():\n            param.requires_grad = True\n\n        # Classifier head always trainable\n        for param in self.backbone.classifier.parameters():\n            param.requires_grad = True\n\n    def forward(self, x):\n        # Backbone conv layers run in float16 under autocast — acceptable\n        x = self.backbone.features(x)\n        x = self.backbone.avgpool(x)\n        x = torch.flatten(x, 1)\n        # Force float32 before classifier head —\n        # BatchNorm1d running stats must never receive float16\n        # or running_mean/running_var become corrupted → val NaN\n        x = x.float()\n        return self.backbone.classifier(x)\n\n\n# ── Initialize ─────────────────────────────────────────────\nmodel = HemorrhageModel().to(DEVICE)\n\n# ── Phase 1: Freeze backbone immediately ───────────────────\nmodel.freeze_backbone()\n\n# ── Summary ────────────────────────────────────────────────\ntotal_params     = sum(p.numel() for p in model.parameters())\ntrainable_params = sum(p.numel() for p in model.parameters()\n                       if p.requires_grad)\nfrozen_params    = total_params - trainable_params\n\nprint(f\"✅ EfficientNet-B3 initialized (multi-label, Phase 1 — backbone frozen).\")\nprint(f\"\\n📋 Model Summary:\")\nprint(f\"  Total parameters     : {total_params:,}\")\nprint(f\"  Trainable parameters : {trainable_params:,}\")\nprint(f\"  Frozen parameters    : {frozen_params:,}\")\nprint(f\"  Device               : {DEVICE}\")\nprint(f\"  Input shape          : (batch, 3, 300, 300)\")\nprint(f\"  Output shape         : (batch, 6) logits\")\nprint(f\"  Labels               : {LABEL_COLS}\")\nprint(f\"\\n📋 Classifier Head Architecture:\")\nprint(f\"  Dropout(0.3) → Linear(1536→512) → BatchNorm1d(512)\")\nprint(f\"  → SiLU → Dropout(0.4) → Linear(512→6)\")\nprint(f\"\\n  Phase 1 — Only classifier head is trainable.\")\nprint(f\"  Call model.unfreeze_top_blocks() to begin Phase 2.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T18:32:12.903532Z","iopub.execute_input":"2026-04-27T18:32:12.903865Z","iopub.status.idle":"2026-04-27T18:32:13.821134Z","shell.execute_reply.started":"2026-04-27T18:32:12.903840Z","shell.execute_reply":"2026-04-27T18:32:13.820494Z"}},"outputs":[{"name":"stdout","text":"Downloading: \"https://download.pytorch.org/models/efficientnet_b3_rwightman-b3899882.pth\" to /root/.cache/torch/hub/checkpoints/efficientnet_b3_rwightman-b3899882.pth\n","output_type":"stream"},{"name":"stderr","text":"100%|██████████| 47.2M/47.2M [00:00<00:00, 157MB/s] \n","output_type":"stream"},{"name":"stdout","text":"✅ E