n","source":"# Local Dataset Preprocessing for Model Testing","metadata":{}},{"cell_type":"code","source":"import os, zipfile, pydicom, numpy as np, pandas as pd\nimport matplotlib.pyplot as plt\nfrom collections import defaultdict\n\n# ─── Paths ────────────────────────────────────────────────────────────────────\nlocal_zip_root = \"/kaggle/input/datasets/muscanaman/local-patients-obaidnoor-hospital\"\nrsna_csv_path  = \"/kaggle/input/competitions/rsna-intracranial-hemorrhage-detection/rsna-intracranial-hemorrhage-detection/stage_2_train.csv\"\nrsna_dcm_dir   = \"/kaggle/input/competitions/rsna-intracranial-hemorrhage-detection/rsna-intracranial-hemorrhage-detection/stage_2_train\"\nextract_path   = \"/kaggle/working/local_obaidnoor\"\nos.makedirs(extract_path, exist_ok=True)\n\n# ─── Step 1: Find and extract zip ─────────────────────────────────────────────\nprint(\"=\"*60)\nprint(\"  STEP 1: LOCATING & EXTRACTING LOCAL DATASET\")\nprint(\"=\"*60)\n\nzip_files = [f for f in os.listdir(local_zip_root) if f.endswith('.zip')]\ndcm_files_direct = [f for f in os.listdir(local_zip_root) if f.endswith('.dcm')]\n\nif zip_files:\n    zip_path = os.path.join(local_zip_root, zip_files[0])\n    print(f\"Found zip: {zip_files[0]}\")\n    with zipfile.ZipFile(zip_path, 'r') as z:\n        z.extractall(extract_path)\n    print(f\"Extracted to: {extract_path}\")\nelif dcm_files_direct:\n    extract_path = local_zip_root\n    print(f\"No zip found — DICOM files already extracted at: {extract_path}\")\nelse:\n    # walk subdirectories\n    for root, dirs, files in os.walk(local_zip_root):\n        dcms = [f for f in files if f.endswith('.dcm')]\n        if dcms:\n            extract_path = root\n            print(f\"Found DICOMs in subfolder: {root}\")\n            break\n\n# ─── Step 2: Walk extracted folder, find all DCM files + CSV ─────────────────\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 2: FOLDER STRUCTURE ANALYSIS\")\nprint(\"=\"*60)\n\nall_dcm, csv_files = [], []\nfor root, dirs, files in os.walk(extract_path):\n    for f in files:\n        if f.endswith('.dcm'): all_dcm.append(os.path.join(root, f))\n        if f.endswith('.csv'): csv_files.append(os.path.join(root, f))\n\nprint(f\"Total DICOM files found : {len(all_dcm)}\")\nprint(f\"CSV files found         : {csv_files if csv_files else 'None'}\")\nif all_dcm:\n    print(f\"Sample file             : {os.path.basename(all_dcm[0])}\")\n\n# ─── Step 3: Load label CSV ───────────────────────────────────────────────────\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 3: LABEL CSV INSPECTION\")\nprint(\"=\"*60)\n\nif csv_files:\n    df_local = pd.read_csv(csv_files[0])\n    print(f\"CSV shape   : {df_local.shape}\")\n    print(f\"Columns     : {df_local.columns.tolist()}\")\n    print(f\"\\nFirst 5 rows:\\n{df_local.head()}\")\n\n    # Pivot if RSNA-style\n    if 'ID' in df_local.columns and 'Label' in df_local.columns:\n        df_local[['slice_id','subtype']] = df_local['ID'].str.rsplit('_', n=1, expand=True)\n        df_local = df_local.pivot_table(\n            index='slice_id', columns='subtype', values='Label', aggfunc='max'\n        ).reset_index()\n        df_local.columns.name = None\n        print(f\"\\nPivoted shape: {df_local.shape}\")\n        print(f\"Columns      : {df_local.columns.tolist()}\")\nelse:\n    # Build labels from filenames\n    print(\"No CSV found — building slice list from filenames\")\n    slice_ids = [os.path.basename(f).replace('.dcm','') for f in all_dcm]\n    df_local  = pd.DataFrame({'slice_id': slice_ids})\n\nprint(f\"\\nLocal slices total: {len(df_local)}\")\n\n# ─── Step 4: Inspect a sample DICOM ──────────────────────────────────────────\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 4: SAMPLE DICOM METADATA\")\nprint(\"=\"*60)\n\nsample_dcm = all_dcm[0]\nds = pydicom.dcmread(sample_dcm)\npixels = ds.pixel_array.astype(np.float32)\nslope     = float(getattr(ds, 'RescaleSlope',     1.0))\nintercept = float(getattr(ds, 'RescaleIntercept', 0.0))\nhu = pixels * slope + intercept\n\nprint(f\"File                : {os.path.basename(sample_dcm)}\")\nprint(f\"Image shape         : {ds.pixel_array.shape}\")\nprint(f\"Pixel spacing       : {getattr(ds,'PixelSpacing','N/A')}\")\nprint(f\"Slice thickness     : {getattr(ds,'SliceThickness','N/A')}\")\nprint(f\"Rescale slope       : {slope}\")\nprint(f\"Rescale intercept   : {intercept}\")\nprint(f\"SOPClassUID         : {getattr(ds,'SOPClassUID','N/A')}\")\nprint(f\"Raw pixel range     : [{pixels.min():.0f}, {pixels.max():.0f}]\")\nprint(f\"HU range            : [{hu.min():.0f}, {hu.max():.0f}]\")\n\n# ─── Step 5: Label distribution ───────────────────────────────────────────────\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 5: LOCAL DATASET LABEL DISTRIBUTION\")\nprint(\"=\"*60)\n\nif 'any' in df_local.columns:\n    hemo   = (df_local['any'] == 1).sum()\n    normal = (df_local['any'] == 0).sum()\n    print(f\"Hemorrhage slices : {hemo}  ({hemo/len(df_local)*100:.1f}%)\")\n    print(f\"Normal slices     : {normal}  ({normal/len(df_local)*100:.1f}%)\")\n    if 'epidural' in df_local.columns:\n        print(f\"\\nSubtype breakdown:\")\n        for col in ['epidural','intraparenchymal','intraventricular','subarachnoid','subdural']:\n            if col in df_local.columns:\n                print(f\"  {col:20s}: {df_local[col].sum()}\")\nelse:\n    print(f\"Total slices (no labels): {len(df_local)}\")\n\n# ─── Step 6: Sample 2000 RSNA normal slices ───────────────────────────────────\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 6: SAMPLING 2000 RSNA NORMAL SLICES\")\nprint(\"=\"*60)\n\nrsna_df = pd.read_csv(rsna_csv_path)\nrsna_df[['slice_id','subtype']] = rsna_df['ID'].str.rsplit('_', n=1, expand=True)\nrsna_wide = rsna_df.pivot_table(\n    index='slice_id', columns='subtype', values='Label', aggfunc='max'\n).reset_index()\nrsna_wide.columns.name = None\n\nrsna_normal_pool = rsna_wide[rsna_wide['any'] == 0]\nrsna_normal_2000 = rsna_normal_pool.sample(n=2000, random_state=42).reset_index